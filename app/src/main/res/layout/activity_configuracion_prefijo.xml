<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PANEL"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Estilo de Lectura"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_volver_prefijo"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="← Volver"
                android:textColor="@color/naranja_primario"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/btn_outline_orange"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>

        <!-- Etiqueta de sección -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OPCIONES"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="12dp" />

        <!-- Card de opciones -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Cómo quieres que EVA anuncie las notificaciones?"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.5"
                    android:layout_marginBottom="16dp" />

                <RadioGroup
                    android:id="@+id/radio_group_prefijo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Opción 1 -->
                    <RadioButton
                        android:id="@+id/radio_notificacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Notificación de [App]: [mensaje]"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:background="?attr/selectableItemBackground"
                        android:checked="true"
                        android:contentDescription="Opción uno: prefijo completo. EVA dirá Notificación de, seguido del nombre de la aplicación y el mensaje." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="44dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp"
                        android:text="Ej: «Notificación de WhatsApp. Juan. Hola»"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.5"
                        android:importantForAccessibility="no" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="?attr/colorOnSurface"
                        android:alpha="0.1"
                        android:layout_marginBottom="4dp" />

                    <!-- Opción 2 -->
                    <RadioButton
                        android:id="@+id/radio_mensaje"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="[App]: [mensaje]"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:background="?attr/selectableItemBackground"
                        android:contentDescription="Opción dos: solo el nombre de la aplicación. EVA dirá el nombre de la aplicación seguido del mensaje, sin decir Notificación de." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="44dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp"
                        android:text="Ej: «WhatsApp. Juan. Hola»"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.5"
                        android:importantForAccessibility="no" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="?attr/colorOnSurface"
                        android:alpha="0.1"
                        android:layout_marginBottom="4dp" />

                    <!-- Opción 3 -->
                    <RadioButton
                        android:id="@+id/radio_sin_prefijo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:text="Solo el mensaje"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface"
                        android:background="?attr/selectableItemBackground"
                        android:contentDescription="Opción tres: solo el mensaje. EVA dirá únicamente el contenido de la notificación, sin mencionar la aplicación." />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="44dp"
                        android:paddingEnd="12dp"
                        android:paddingBottom="12dp"
                        android:text="Ej: «Juan. Hola»"
                        android:textSize="12sp"
                        android:textColor="?attr/colorOnSurface"
                        android:alpha="0.5"
                        android:importantForAccessibility="no" />

                </RadioGroup>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón guardar -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_guardar_prefijo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Guardar Preferencia"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_gradient_orange"
            android:layout_marginBottom="12dp" />

        <!-- Nota -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="3dp"
                    android:layout_height="40dp"
                    android:background="@color/naranja_primario"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="El estilo elegido se aplica a todas las notificaciones que EVA lee en voz alta."
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.6"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
