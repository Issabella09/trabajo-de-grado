<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_gradient"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header con logo/título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:layout_marginBottom="16dp">

            <!-- Logo de EVA -->
            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/logo_eva"
                android:contentDescription="Logo EVA"
                android:elevation="8dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EVA"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/naranja_primario"
                android:letterSpacing="0.05"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asistente Virtual"
                android:textSize="16sp"
                android:textColor="@color/gris_medio"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- Card de Configuración Inicial -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/blanco">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configuración Inicial"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/negro"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Para usar EVA, primero activa los permisos de accesibilidad:"
                    android:textSize="14sp"
                    android:textColor="@color/gris_oscuro"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="16dp" />

                <!-- Botón de Accesibilidad CORREGIDO -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnActivarServicio"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Ir a Permisos de Accesibilidad"
                    android:textColor="@color/blanco"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/btn_gradient_orange"
                    android:textAllCaps="false"
                    android:elevation="4dp" />

                <!-- Botón de Control CORREGIDO -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnIrAControl"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Abrir Panel de Control"
                    android:textColor="@color/naranja_primario"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:enabled="false"
                    android:background="@drawable/btn_outline_orange_selector" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card de Funciones Principales -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/blanco">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Funciones"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/negro"
                    android:layout_marginBottom="16dp" />

                <!-- Asistente de Voz -->
                <LinearLayout
                    android:id="@+id/btnAsistenteVoz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@drawable/btn_gradient_orange"
                    android:gravity="center_vertical"
                    android:elevation="4dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🎤"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@android:color/white"
                        android:backgroundTint="#20FFFFFF" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Asistente de Voz"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/blanco" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Di 'EVA' para dar comandos"
                            android:textSize="12sp"
                            android:textColor="#E0FFFFFF" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="24sp"
                        android:textColor="@color/blanco" />
                </LinearLayout>

                <!-- Lector de Texto -->
                <LinearLayout
                    android:id="@+id/btnAbrirOCR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@drawable/card_background"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="📖"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/btn_gradient_orange"
                        android:backgroundTint="#20FF6B35" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lector de Texto"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/negro" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Escanea y lee texto"
                            android:textSize="12sp"
                            android:textColor="@color/gris_medio" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="24sp"
                        android:textColor="@color/naranja_primario" />
                </LinearLayout>

                <!-- Notificaciones -->
                <LinearLayout
                    android:id="@+id/btnNotificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:background="@drawable/card_background"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🔔"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="@drawable/btn_gradient_orange"
                        android:backgroundTint="#20FF6B35" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lectura de Notificaciones"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/negro" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Escucha tus mensajes"
                            android:textSize="12sp"
                            android:textColor="@color/gris_medio" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="→"
                        android:textSize="24sp"
                        android:textColor="@color/naranja_primario" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Card de Instrucciones -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFF8F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡 Cómo usar"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/naranja_primario"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Configura accesibilidad\n2. Busca 'EVA' en la lista\n3. Activa el interruptor\n4. Regresa aquí y usa las funciones"
                    android:textSize="14sp"
                    android:textColor="@color/gris_oscuro"
                    android:lineSpacingExtra="6dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>