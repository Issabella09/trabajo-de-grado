<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/img_icon_detallada"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Ícono de app" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/txt_nombre_detallada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WhatsApp"
            android:textSize="15sp"
            android:textColor="@color/negro"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txt_package_detallada"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="com.whatsapp"
            android:textSize="11sp"
            android:textColor="@color/gris_medio"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/checkbox_detallada"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/naranja_primario" />

</LinearLayout>