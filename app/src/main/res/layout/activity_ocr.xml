<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFF7F2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lector de texto"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#F97316"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp" />

        <!-- CARD ACCIONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="6dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Selecciona una opción"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F2933"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnTomarFoto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tomar foto con la cámara"
                android:textSize="16sp"
                android:padding="16dp"
                android:textColor="@android:color/white"
                android:backgroundTint="#F97316"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnElegirGaleria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Elegir imagen de la galería"
                android:textSize="16sp"
                android:padding="16dp"
                android:textColor="@android:color/white"
                android:backgroundTint="#EA580C" />
        </LinearLayout>

        <!-- PREVIEW CÁMARA -->
        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- CARD TEXTO DETECTADO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:elevation="6dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Texto detectado"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1F2933"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtInstrucciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Toma una foto o elige una imagen para detectar el texto"
                android:textSize="15sp"
                android:textColor="#374151"
                android:layout_marginBottom="12dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="160dp">

                <TextView
                    android:id="@+id/txtResultado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aquí aparecerá el texto detectado..."
                    android:textSize="16sp"
                    android:textColor="#374151"
                    android:lineSpacingExtra="6dp" />
            </ScrollView>
        </LinearLayout>

        <!-- BOTÓN LEER -->
        <Button
            android:id="@+id/btnLeerVoz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Leer en voz alta"
            android:textSize="16sp"
            android:padding="16dp"
            android:textColor="@android:color/white"
            android:backgroundTint="#F97316"
            android:layout_marginBottom="16dp" />

        <!-- VOLVER -->
        <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Volver al inicio"
            android:textSize="16sp"
            android:padding="16dp"
            android:textColor="@android:color/white"
            android:backgroundTint="#EA580C" />

    </LinearLayout>
</ScrollView>
