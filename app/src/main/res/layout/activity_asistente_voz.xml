<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Asistente de Voz EVA"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/naranja_primario"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp" />

    <!-- Estado -->
    <TextView
        android:id="@+id/txtEstadoAsistente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Verificando permisos..."
        android:textSize="16sp"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/naranja_claro"
        android:layout_marginBottom="30dp" />

    <!-- Switch activación -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="30dp">

        <Switch
            android:id="@+id/switchAsistenteVoz"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Activar Asistente de Voz"
            android:textSize="18sp"
            android:enabled="false" />

    </LinearLayout>

    <!-- Instrucciones -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/comandos_disponibles"
        android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:padding="16dp"
        android:background="#F5F5F5"
        android:layout_marginBottom="30dp" />

    <!-- Botón volver -->
    <Button
        android:id="@+id/btnVolverAsistente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Volver al Inicio"
        android:textColor="@color/white"
        android:backgroundTint="@color/naranja_oscuro"
        android:textSize="16sp" />

</LinearLayout>