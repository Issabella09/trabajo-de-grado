<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ASISTENTE"
                    android:textSize="11sp"
                    android:letterSpacing="0.15"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EVA"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/naranja_primario" />
            </LinearLayout>

            <!-- Badge estado EVA -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/colorSurface"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <View
                    android:id="@+id/viewEstadoPunto"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/card_background"
                    android:backgroundTint="@color/acento_verde"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tv_estado_eva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Di 'EVA' seguido de tu comando"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.6" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card activación -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/naranja_primario">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVAR EVA"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:textColor="#CCFFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escucha continua activada"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_eva"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Último comando -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ÚLTIMO COMANDO"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="3dp"
                    android:layout_height="40dp"
                    android:background="@color/naranja_primario"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/tv_ultimo_comando"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ninguno aún"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Respuesta -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESPUESTA"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <View
                    android:layout_width="3dp"
                    android:layout_height="40dp"
                    android:background="@color/naranja_primario"
                    android:layout_marginEnd="16dp" />

                <TextView
                    android:id="@+id/tv_respuesta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Esperando comando..."
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Comandos disponibles -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMANDOS DISPONIBLES"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="3dp" android:layout_height="14dp"
                        android:background="@color/naranja_primario" android:layout_marginEnd="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="¿Qué hora es?" android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="3dp" android:layout_height="14dp"
                        android:background="@color/naranja_primario" android:layout_marginEnd="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="¿Qué día es hoy?" android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="3dp" android:layout_height="14dp"
                        android:background="@color/naranja_primario" android:layout_marginEnd="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Cuéntame un chiste" android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="3dp" android:layout_height="14dp"
                        android:background="@color/naranja_primario" android:layout_marginEnd="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="¿Cómo está el clima?" android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View android:layout_width="3dp" android:layout_height="14dp"
                        android:background="@color/naranja_primario" android:layout_marginEnd="12dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Busca [algo] en internet" android:textSize="14sp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>