<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registro"
                android:textSize="40sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <View
                    android:layout_width="24dp"
                    android:layout_height="3dp"
                    android:background="@color/naranja_primario" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Crea tu cuenta en EVA"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurface"
                    android:alpha="0.5" />
            </LinearLayout>
        </LinearLayout>

        <!-- Nombre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOMBRE COMPLETO"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etNombre"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Tu nombre"
            android:inputType="textPersonName"
            android:background="@drawable/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CORREO ELECTRÓNICO"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="correo@ejemplo.com"
            android:inputType="textEmailAddress"
            android:background="@drawable/card_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <!-- Contraseña -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONTRASEÑA"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="?attr/colorOnSurface"
            android:alpha="0.4"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/card_background"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Mínimo 6 caracteres"
                android:inputType="textPassword"
                android:background="@android:color/transparent"
                android:paddingStart="16dp"
                android:textSize="15sp" />

            <ImageButton
                android:id="@+id/btnTogglePassword"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_eye_off"
                android:padding="12dp"
                app:tint="@color/gris_medio"
                android:contentDescription="Mostrar contraseña" />
        </LinearLayout>

        <!-- Botón crear cuenta -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRegistrar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Crear Cuenta"
            android:textColor="@color/blanco"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/btn_gradient_orange"
            android:layout_marginBottom="12dp" />

        <!-- Divisor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:layout_weight="1"
                android:background="?attr/colorOnSurface"
                android:alpha="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  o  "
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.3" />

            <View
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:layout_weight="1"
                android:background="?attr/colorOnSurface"
                android:alpha="0.1" />
        </LinearLayout>

        <!-- Volver al login -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVolverLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Ya tengo cuenta"
            android:textColor="@color/naranja_primario"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:background="@drawable/btn_outline_orange"
            android:layout_marginBottom="32dp" />

        <ProgressBar
            android:id="@+id/progressRegistro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>